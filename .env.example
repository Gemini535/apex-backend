# Database
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/apex?schema=public"

# Server
PORT=3000
NODE_ENV=development

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_RANDOM_256_BIT_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_TO_DIFFERENT_RANDOM_256_BIT_SECRET
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# OAuth - Apple
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 2FA
TOTP_ISSUER=Apex

# Twilio (SMS 2FA)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Email (2FA & notifications)
SMTP_HOST=
SMTP_PORT=578
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@apex-app.com

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
