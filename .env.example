# ─────────────────────────────────────────────────────────────────────────────
# Apex Backend — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the real values. NEVER commit `.env`.
# Every variable below has a sensible default where possible; required ones
# (no default) will crash the server at startup with a clear error if missing.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string. For local dev with Docker:
#   postgresql://postgres:postgres@localhost:5432/apex?schema=public
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/apex?schema=public"

# ─── Server ──────────────────────────────────────────────────────────────────
# Port the HTTP server listens on.
PORT=3000
# Runtime environment: "development" | "production" | "test".
# Controls log verbosity, CORS, error detail leakage, and secret warnings.
NODE_ENV=development

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate strong random secrets with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# JWT_SECRET signs short-lived access tokens. MUST be ≥24 chars, not a placeholder.
JWT_SECRET=CHANGE_ME_TO_RANDOM_256_BIT_SECRET
# JWT_REFRESH_SECRET signs refresh tokens. MUST differ from JWT_SECRET.
JWT_REFRESH_SECRET=CHANGE_ME_TO_DIFFERENT_RANDOM_256_BIT_SECRET
# Access token lifetime. Default 15m. Short = more secure.
JWT_ACCESS_EXPIRY=15m
# Refresh token lifetime. Default 7d.
JWT_REFRESH_EXPIRY=7d

# ─── OAuth - Apple ───────────────────────────────────────────────────────────
# Apple Sign-In service identifier (e.g. com.apex.app). Leave blank to disable.
APPLE_CLIENT_ID=
# Apple Developer Team ID (10 chars).
APPLE_TEAM_ID=
# Private key ID for Apple Sign-In.
APPLE_KEY_ID=
# Path to the .p8 private key file downloaded from Apple Developer Portal.
APPLE_PRIVATE_KEY_PATH=

# ─── OAuth - Google ──────────────────────────────────────────────────────────
# OAuth client ID & secret from Google Cloud Console. Leave blank to disable.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── 2FA ─────────────────────────────────────────────────────────────────────
# Issuer name shown in the authenticator app (e.g. Google Authenticator).
TOTP_ISSUER=Apex

# ─── Twilio (SMS 2FA) ────────────────────────────────────────────────────────
# Twilio credentials for sending SMS verification codes. Leave blank to disable.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Twilio phone number in E.164 format (e.g. +15551234567).
TWILIO_PHONE_NUMBER=

# ─── SMTP (Email 2FA & notifications) ────────────────────────────────────────
# Mail server for sending verification and reset emails. Leave blank to disable.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# "From" address on outgoing emails.
SMTP_FROM=noreply@apex-app.com

# ─── Stripe (Payments) ───────────────────────────────────────────────────────
# Secret key from the Stripe dashboard. Use sk_test_* for development.
# The server warns at startup if a test key is used with NODE_ENV=production.
STRIPE_SECRET_KEY=sk_test_your_key_here
# Signing secret from your Stripe webhook endpoint (whsec_*).
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# General global limiter: RATE_LIMIT_MAX requests per RATE_LIMIT_WINDOW_MS.
# Default: 100 requests per 15 minutes.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
# Note: auth routes (login, password reset, email verify) use a stricter fixed
# limit of 5 per 15 min, and the token wheel uses 10/min by user. These are
# not configurable via env by design — they're security-critical.

# ─── CORS (Production) ───────────────────────────────────────────────────────
# The allowed frontend origin in production. Used when NODE_ENV=production.
# In development, CORS is wide-open ("*") for convenience.
FRONTEND_URL=https://apex-app.com

# ─── Cache (in-memory) ────────────────────────────────────────────────────────
# All caches are per-process (no Redis). Each Node instance has its own cache
# state — restart clears it. For multi-instance deployments, reduce TTLs or
# disable the cache so reads hit the database directly.
#
# Master switch. Set CACHE_ENABLED=false to bypass all caches (useful in tests
# or when debugging stale-data issues).
CACHE_ENABLED=true

# Per-entry time-to-live in milliseconds. A user's brain state only changes on
# screen-time upload; a balance or friend list changes on writes that are
# already guarded by an explicit invalidate() call.
CACHE_TTL_BRAIN_STATE_MS=300000       # 5 minutes
CACHE_TTL_FRIENDS_MS=30000            # 30 seconds
CACHE_TTL_BALANCE_MS=60000            # 1 minute

# Maximum entries per keyspace. When exceeded, the least-recently-used entry is
# evicted. Keeps memory bounded on large deployments.
CACHE_MAX_ENTRIES=5000

# ─── Queue (pg-boss) ──────────────────────────────────────────────────────────
# pg-boss uses DATABASE_URL to store jobs inside a dedicated schema (`pgboss`).
# No separate Redis or external service is needed.
#
# Queue workers read DATABASE_URL; they all come from the same connection string.
# If running a standalone worker process instead of inline in the HTTP server,
# set the two env vars below on that worker's host.
# WORKER_HTTP_PORT=4001    # only for a separate worker-process container
